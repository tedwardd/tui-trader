VIRTUAL_ENV="$(pwd)/.venv"
PATH_add "$VIRTUAL_ENV/bin"
export VIRTUAL_ENV

if [ -f requirements.txt ]; then
  watch_file requirements.txt
  if [ ! -f "$VIRTUAL_ENV/.requirements.stamp" ] || \
     [ requirements.txt -nt "$VIRTUAL_ENV/.requirements.stamp" ]; then
    pip install -r requirements.txt && touch "$VIRTUAL_ENV/.requirements.stamp"
  fi
fi
