# tui-trader configuration example
# Copy this file to ~/.config/tui-trader/config.env and fill in your values.
# The app will create this file automatically on first run, but this example
# serves as a reference for all available options.

# --- Kraken API credentials ---
# Generate at: https://www.kraken.com/u/security/api
# Required permissions: Query Funds, Query/Create/Cancel Orders, Query Trades
KRAKEN_API_KEY=your_api_key_here
KRAKEN_API_SECRET=your_api_secret_here

# --- Trading defaults ---
# Default trading pair shown on startup
DEFAULT_SYMBOL=BTC/USD

# --- Refresh / timing ---
# History screen REST refresh interval (seconds)
HISTORY_REFRESH_SECONDS=60

# WebSocket reconnect backoff (seconds)
WS_RECONNECT_BACKOFF=5

# --- Risk management ---
# Default stop-loss percentage used when no manual stop is set
DEFAULT_STOP_LOSS_PCT=2.0

# --- Order book ---
# Depth of the order book display (must be one of: 10, 25, 100, 500, 1000)
ORDER_BOOK_DEPTH=10

# --- Cloud Database Sync (optional) ---
# Syncs the local SQLite database to any S3-compatible object storage provider.
# Recommended free provider: Cloudflare R2 (10 GB free, no egress fees).
#
# Setup (Cloudflare R2):
#   1. Create a free Cloudflare account at https://cloudflare.com
#   2. Navigate to R2 → Create bucket (e.g. "tui-trader-db")
#   3. R2 → Manage R2 API Tokens → Create token with Read + Write on that bucket
#   4. Copy the endpoint URL, Key ID, and Secret into the fields below
#   5. Set CLOUD_SYNC_ENABLED=true
#
# Leave CLOUD_SYNC_ENABLED=false (or comment out this section) for local-only mode.
#
# If two sessions are open simultaneously, the second session will be read-only.
# To recover from a crashed session that left a stale lock:
#   .venv/bin/python main.py --force-unlock
#
# CLOUD_SYNC_ENABLED=false
# CLOUD_SYNC_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# CLOUD_SYNC_BUCKET=tui-trader-db
# CLOUD_SYNC_KEY_ID=
# CLOUD_SYNC_KEY_SECRET=
# CLOUD_SYNC_OBJECT_KEY=trades.db
